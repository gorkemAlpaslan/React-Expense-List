["56","57"],"C:\\Users\\gorki\\Desktop\\01-starting-setup\\src\\App.js",[],"C:\\Users\\gorki\\Desktop\\01-starting-setup\\src\\components\\Expenses\\Expenses.js",["58"],"import React, { useState } from \"react\";\r\nimport ExpensesFilter from \"./ExpensesFilter\";\r\nimport Card from \"../UI/Card\";\r\nimport ExpenseItem from \"./ExpenseItem\";\r\nimport \"./Expenses.css\";\r\nimport ExpensesList from \"./ExpensesList\";\r\nimport ExpensesChart from \"./ExpensesChart\";\r\n\r\nconst Expenses = (props) => {\r\n  const [filteredYear, setFilteredYear] = useState(\"2020\");\r\n  const filterChangeHandler = (selectedYear) => {\r\n    setFilteredYear(selectedYear);\r\n  };\r\n\r\n  const filteredExpenses = props.items.filter((expense) => {\r\n    return expense.date.getFullYear().toString() === filteredYear;\r\n  });\r\n\r\n  return (\r\n    <div>\r\n      <Card className=\"expenses\">\r\n        <ExpensesFilter\r\n          selected={filteredYear}\r\n          onExpensesFilterChanged={filterChangeHandler}\r\n        ></ExpensesFilter>\r\n        <ExpensesChart expenses={filteredExpenses}></ExpensesChart>\r\n        <ExpensesList expenseFilter={filteredExpenses}></ExpensesList>\r\n      </Card>\r\n    </div>\r\n  );\r\n};\r\n\r\nexport default Expenses;\r\n","C:\\Users\\gorki\\Desktop\\01-starting-setup\\src\\components\\Expenses\\ExpenseItem.js",[],"C:\\Users\\gorki\\Desktop\\01-starting-setup\\src\\components\\Expenses\\ExpenseDate.js",[],"C:\\Users\\gorki\\Desktop\\01-starting-setup\\src\\components\\UI\\Card.js",[],"C:\\Users\\gorki\\Desktop\\01-starting-setup\\src\\components\\NewExpense\\NewExpense.js",[],"C:\\Users\\gorki\\Desktop\\01-starting-setup\\src\\components\\NewExpense\\ExpenseForm.js",[],"C:\\Users\\gorki\\Desktop\\01-starting-setup\\src\\components\\Expenses\\ExpensesFilter.js",[],"C:\\Users\\gorki\\Desktop\\01-starting-setup\\src\\components\\Expenses\\ExpensesList.js",[],"C:\\Users\\gorki\\Desktop\\01-starting-setup\\src\\components\\Chart\\ChartBar.js